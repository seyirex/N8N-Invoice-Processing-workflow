# ──────────────────────────────────────────────────────────────
# n8n Invoice Processing — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
# ──────────────────────────────────────────────────────────────

# ── n8n Core ──────────────────────────────────────────────────
# Required: sets the host n8n binds to (leave as 0.0.0.0 for Docker)
N8N_HOST=0.0.0.0

# Port n8n listens on inside the container (Docker maps this to 5678 on host)
N8N_PORT=5678

# Protocol used for webhook URLs (http for local, https for production)
N8N_PROTOCOL=http

# Required for production — set to your public domain (e.g. n8n.yourdomain.com)
# Leave blank for local Docker usage
WEBHOOK_URL=

# Timezone for scheduled triggers (e.g. America/New_York, Europe/London, UTC)
GENERIC_TIMEZONE=UTC

# ── n8n Performance ───────────────────────────────────────────
# Use websocket for real-time push updates in the UI
N8N_PUSH_BACKEND=websocket

# Keep binary data (PDFs, images) in memory — required for Gemini image extraction
N8N_DEFAULT_BINARY_DATA_MODE=default

# ── Encryption ────────────────────────────────────────────────
# IMPORTANT: Set this to a random 32-character string to encrypt credentials at rest.
# Generate one with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=REPLACE_WITH_RANDOM_32_CHAR_STRING 
